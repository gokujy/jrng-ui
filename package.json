{
  "name": "jrng-ui-workspace",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng build jrng-ui && ng serve docs",
    "build": "ng build jrng-ui && ng build docs",
    "build:lib": "ng build jrng-ui",
    "build:docs": "ng build docs",
    "watch": "ng build --watch --configuration development",
    "test": "ng build jrng-ui && ng test --watch=false",
    "test:lib": "ng test jrng-ui --watch=false",
    "test:docs": "ng build jrng-ui && ng test docs --watch=false"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.17",
    "@angular/cli": "^21.2.17",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "esbuild": "0.28.1",
    "undici": "7.28.0"
  }
}
