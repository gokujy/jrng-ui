{
  "name": "jrng-ui-workspace",
  "version": "0.1.0",
  "description": "A modern Angular component library for admin panels, dashboards and business applications.",
  "homepage": "https://jrngui.dev/",
  "keywords": [
    "angular",
    "ui",
    "components",
    "component-library",
    "standalone-components",
    "design-system",
    "accessibility",
    "reactive-forms",
    "ssr",
    "zoneless",
    "dashboard",
    "admin-dashboard",
    "business-ui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gokujy/jrng-ui.git"
  },
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "clean": "node scripts/clean.mjs",
    "start": "npm run build:lib && ng serve docs",
    "build": "npm run build:docs",
    "build:lib": "node scripts/generate-public-registry.mjs && ng build jrng-ui && node scripts/prepare-package.mjs",
    "build:docs": "npm run build:lib && npm run build:docs:app",
    "build:docs:app": "npm run docs:inventory && npm run generate:docs-registry && npm run generate:demos && npm run generate:sitemap && npm run verify:doc-examples && ng build docs",
    "build:ssr": "npm run build:lib && ng build ssr-smoke",
    "build:clean": "npm run clean && npm run build:lib && npm run build:docs:app",
    "typecheck": "ng build jrng-ui --configuration development && ng build docs --configuration development",
    "typecheck:library": "npm run typecheck",
    "generate:docs-registry": "node scripts/generate-doc-registry.mjs",
    "docs:inventory": "node scripts/generate-component-inventory.mjs",
    "docs:check-completeness": "node scripts/check-doc-completeness.mjs",
    "docs:check-routes": "node scripts/check-doc-routes.mjs",
    "docs:check-examples": "node scripts/check-doc-examples.mjs",
    "docs:reports": "node scripts/generate-component-quality-reports.mjs",
    "docs:audit": "npm run docs:inventory && npm run generate:docs-registry && npm run docs:check-completeness && npm run docs:check-routes && npm run docs:check-examples && npm run docs:reports",
    "generate:demos": "node scripts/generate-demo-sources.mjs",
    "generate:contract-specs": "node scripts/generate-missing-contract-specs.mjs",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "generate:enterprise-audits": "npm run build:lib && node scripts/generate-component-inventory.mjs && node scripts/generate-enterprise-audits.mjs",
    "verify:docs-registry": "node scripts/verify-doc-registry.mjs",
    "verify:docs-links": "node scripts/verify-doc-links.mjs",
    "verify:doc-examples": "node scripts/verify-doc-examples.mjs",
    "verify:spec-coverage": "node scripts/verify-spec-coverage.mjs",
    "verify:registry": "node scripts/verify-public-registry.mjs",
    "audit:inputs": "node scripts/audit-public-inputs.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "npm run build:lib && ng test --watch=false",
    "test:lib": "npm run build:lib && ng test jrng-ui --watch=false",
    "test:coverage": "npm run build:lib && ng test jrng-ui --watch=false --coverage",
    "test:docs": "npm run build:lib && ng test docs --watch=false",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,html,scss,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,html,scss,json,md}\"",
    "pack:dry-run": "npm run build:lib && npm pack ./dist/jrng-ui --dry-run",
    "pack:lib": "npm run build:lib && npm pack ./dist/jrng-ui",
    "verify:package": "node scripts/verify-package.mjs",
    "verify:ssr": "npm run build:ssr",
    "verify:consumer": "node scripts/verify-consumer.mjs",
    "report:package-size": "npm run build:lib && node scripts/verify-package.mjs --skip-build --report",
    "verify:api": "node scripts/verify-public-api.mjs",
    "verify:enterprise-audits": "node scripts/verify-enterprise-audits.mjs",
    "verify:visual-manifest": "node scripts/verify-enterprise-audits.mjs",
    "verify:circular": "node scripts/verify-enterprise-audits.mjs",
    "verify:optional-dependencies": "node scripts/verify-enterprise-audits.mjs",
    "quality:enterprise": "npm run generate:enterprise-audits && npm run verify:enterprise-audits && npm run verify:api && npm run verify:registry && npm run verify:spec-coverage && npm run verify:package && npm run verify:consumer && npm run verify:ssr",
    "verify:release": "node scripts/verify-release.mjs",
    "release:check": "node scripts/verify-release.mjs",
    "release:validate": "node scripts/verify-release.mjs",
    "prepack": "node scripts/prevent-workspace-pack.mjs",
    "prepare": "husky"
  },
  "private": true,
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "packageManager": "npm@11.6.2",
  "lint-staged": {
    "*.{ts,html}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{scss,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.17",
    "@angular/cli": "^21.2.17",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/platform-server": "^21.2.17",
    "@angular/ssr": "^21.2.17",
    "@types/node": "^24.10.0",
    "@vitest/coverage-v8": "^4.1.10",
    "angular-eslint": "^21.4.0",
    "chart.js": "^4.5.1",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^17.0.8",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "esbuild": "0.28.1",
    "undici": "7.28.0"
  }
}
