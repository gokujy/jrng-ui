{
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "../../dist/jrng-ui",
  "lib": {
    "entryFile": "src/public-api.ts"
  },
  "assets": [
    {
      "input": "src/styles",
      "glob": "**/*",
      "output": "theme"
    },
    {
      "input": "registry",
      "glob": "*.json",
      "output": "registry"
    }
  ]
}
