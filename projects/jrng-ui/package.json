{
  "name": "jrng-ui",
  "version": "0.1.0",
  "description": "A modern Angular component library for admin panels, dashboards and business applications.",
  "homepage": "https://jrngui.dev/",
  "keywords": [
    "angular",
    "ui",
    "components",
    "component-library",
    "standalone-components",
    "design-system",
    "accessibility",
    "reactive-forms",
    "ssr",
    "zoneless",
    "dashboard",
    "admin-dashboard",
    "business-ui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gokujy/jrng-ui.git"
  },
  "license": "MIT",
  "files": [
    "fesm2022",
    "types",
    "theme",
    "registry",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "peerDependencies": {
    "@angular/common": ">=21.2.0 <22.0.0",
    "@angular/core": ">=21.2.0 <22.0.0",
    "@angular/forms": ">=21.2.0 <22.0.0",
    "@angular/platform-browser": ">=21.2.0 <22.0.0",
    "@angular/router": ">=21.2.0 <22.0.0",
    "chart.js": "^4.0.0",
    "rxjs": "^7.8.0"
  },
  "peerDependenciesMeta": {
    "@angular/router": {
      "optional": true
    },
    "chart.js": {
      "optional": true
    }
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "exports": {
    "./registry": "./registry/registry.json",
