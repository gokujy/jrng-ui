    "./styles": {
      "sass": "./theme/jrng-ui.scss",
      "style": "./theme/jrng-ui.css"
    },
    "./theme": {
      "sass": "./theme/jrng-ui.scss",
      "style": "./theme/jrng-ui.css"
    }
  },
